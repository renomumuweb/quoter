APP_ENV=development
API_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quoter?sslmode=disable
JWT_SECRET=replace-this-with-at-least-24-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720
BCRYPT_COST=12
RUN_MIGRATIONS=true
MIGRATIONS_DIR=migrations
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Reserved for the file upload phase. Keep real AWS secrets out of this file.
AWS_REGION=us-east-1
S3_BUCKET=
S3_UPLOAD_PREFIX=uploads/
